# Docker 部署环境变量示例 — 与根目录 env.example 保持一致
# 用法: cp env.example .env && 编辑后 docker compose up

API_SERVICE_ENV=prod
API_SERVICE_PORT=8000
LOG_LEVEL=INFO
WEB_CONCURRENCY=4
ENABLE_SCHEDULER=1

MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_DB=yunshu_api_data_platform
MYSQL_USER=root
MYSQL_PASSWORD=CHANGE_ME
MYSQL_POOL_SIZE=100

REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_ENABLE=true

ENCRYPTION_KEY=CHANGE_ME_generate_fernet_key
ALLOWED_ORIGINS=*
USE_ORACLE_THICK_MODE=1
AUDIT_RESPONSE_BODY_MAX_CHARS=4096

SSO_API_URL=https://yovole.net/api/v1/user/check/login
SSO_ACCESS_TOKEN=CHANGE_ME
SSO_REQUEST_SYSTEM=YUNSHU_API_DATA_PLATFORM
SSO_REQUEST_BUSINESS=USER-LOGIN
SSO_TIMEOUT=30
