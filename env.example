API_SERVICE_ENV=dev
API_SERVICE_PORT=8000
LOG_LEVEL=INFO

# Gunicorn / Scheduler
WEB_CONCURRENCY=4
ENABLE_SCHEDULER=1

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=yunshu_api_data_platform
MYSQL_USER=root
MYSQL_PASSWORD=CHANGE_ME
MYSQL_POOL_SIZE=100

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_ENABLE=true

# Security — generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_generate_fernet_key

# CORS (comma-separated origins in production, e.g. https://app.example.com)
ALLOWED_ORIGINS=*

# Oracle Thick Mode (0=thin, 1=thick)
USE_ORACLE_THICK_MODE=0

# Audit log response body max chars (0=disable capture)
AUDIT_RESPONSE_BODY_MAX_CHARS=4096

# SSO Configuration (dev defaults — override in production)
SSO_API_URL=https://yovole.net/api/v1/user/check/login
SSO_ACCESS_TOKEN=CHANGE_ME
SSO_REQUEST_SYSTEM=YUNSHU_API_DATA_PLATFORM
SSO_REQUEST_BUSINESS=USER-LOGIN
SSO_TIMEOUT=30

# Frontend (Vite dev only)
# VITE_API_BASE_URL=
# VITE_APP_VERSION=1.0.0
